{
  "name": "@unscrambled/hubspot",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "nodemon --exec \"npx tsup src/index.ts --dts\" --watch src --ext ts,js",
    "lint": "eslint src/**.ts",
    "prettier:check": "prettier --check src",
    "compile": "tsc --noEmit",
    "build": "tsup src/index.ts --dts",
    "docs:extract": "api-extractor run --local --verbose"
  },
  "dependencies": {
    "zod": "^4.0.17"
  },
  "peerDependencies": {
    "@unscrambled/sdk": ">=0.1.0 <1.0.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.38.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/nodemon": "^1.19.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@unscrambled/sdk": "workspace:*",
    "api-extractor-config": "workspace:*",
    "eslint": "^10.1.0",
    "eslint-config-custom": "*",
    "nodemon": "^2.0.19",
    "tsconfig": "workspace:*",
    "tsdoc-config": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unscrambled-ai/unscrambled.git",
    "directory": "packages/@unscrambled/hubspot"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts"
}
