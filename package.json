{
  "name": "integration-public",
  "version": "0.0.0",
  "private": true,
  "main": "build/index.js",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/@unscrambled/*",
    "packages/util/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:docs": "turbo run build:docs",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "prettier": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prettier:check": "turbo run prettier:check",
    "prettier:write": "turbo run prettier:write",
    "compile": "turbo run compile",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "docs:extract": "turbo run docs:extract",
    "docs:document": "mkdir -p temp/@unscrambled; api-documenter markdown --input-folder temp/@unscrambled --output-folder apps/docs/docs/api",
    "docs:generate": "pnpm run docs:extract && pnpm run docs:document && pnpm run build:docs",
    "docs:generate:dev": "pnpm run docs:extract; pnpm run docs:document",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "^7.26.27",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint-config-custom": "workspace:*",
    "jiti": "^2.4.2",
    "prettier": "2.8.7",
    "turbo": "1.9.1",
    "vite": "^6.4.1",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "packageManager": "pnpm@8.15.3",
  "dependencies": {
    "@changesets/cli": "^2.30.0",
    "@unscrambled/sdk": "workspace:^"
  },
  "pnpm": {
    "overrides": {
      "@eslint/plugin-kit@<0.3.4": "0.3.4",
      "@babel/runtime@<7.26.10": "7.26.10",
      "brace-expansion@>=1.0.0 <1.1.12": "1.1.12",
      "ajv@<6.14.0": "6.14.0",
      "ajv@>=8.0.0 <8.18.0": "8.18.0",
      "body-parser@<1.20.3": "1.20.3",
      "braces@<3.0.3": "3.0.3",
      "cookie@<0.7.0": "0.7.0",
      "express@<4.20.0": "4.20.0",
      "flatted@<3.4.2": "3.4.2",
      "form-data@<3.0.4": "3.0.4",
      "glob@>=10.2.0 <10.5.0": "10.5.0",
      "http-proxy-middleware@<2.0.9": "2.0.9",
      "js-yaml@<3.14.2": "3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "lodash@>=4.0.0 <4.17.23": "4.17.23",
      "markdown-it@>=13.0.0 <14.1.1": "14.1.1",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": "13.2.1",
      "micromatch@<4.0.8": "4.0.8",
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "node-forge@<1.3.2": "1.3.2",
      "on-headers@<1.1.0": "1.1.0",
      "prismjs@<1.30.0": "1.30.0",
      "path-to-regexp@<0.1.12": "0.1.12",
      "qs@<6.14.2": "6.14.2",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "path-to-regexp@>=0.2.0 <1.9.0": "1.9.0",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "send@<0.19.0": "0.19.0",
      "serialize-javascript@<7.0.3": "7.0.3",
      "svgo@>=3.0.0 <3.3.3": "3.3.3",
      "vite@>=6.0.0 <6.4.1": "6.4.1",
      "webpack@>=5.49.0 <5.104.0": "5.104.0",
      "webpack-dev-server@<=5.2.0": "5.2.1"
    }
  }
}
